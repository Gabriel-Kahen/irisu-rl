    "driver_source_lines": [
      "import ctypes, importlib.util, json, statistics",
      "from numbers import Integral, Real",
      "from pathlib import Path",
      "import irisu_env.exact_ipc as ipc",
      "import irisu_env.padded as pad",
      "p=Path('benchmarks/exact_pipeline.py').resolve(); spec=importlib.util.spec_from_file_location('bench',p); bench=importlib.util.module_from_spec(spec); spec.loader.exec_module(bench)",
      "w=Path('build-physics-integration-exact-multiworld-2/irisu-exact-worker').resolve()",
      "new_pack=ipc._pack_step_request; new_decode=pad._decode_exact_transition",
      "fields=('reward','event_count','config_hash','finish_call_count','recorded_final_score','recorded_final_clears','latest_final_score','latest_final_clears','recorded_final_highest_chain','recorded_final_level','latest_final_highest_chain','latest_final_level','terminated','truncated','terminal_metadata_recorded','invalid_action')",
      "def old_pack(kind,x,y,wait_ticks,suppress_fresh_edges=False):",
      " if not isinstance(kind,Integral) or isinstance(kind,bool): raise TypeError",
      " if not isinstance(wait_ticks,Integral) or isinstance(wait_ticks,bool): raise TypeError",
      " if not isinstance(x,Real) or isinstance(x,bool): raise TypeError",
      " if not isinstance(y,Real) or isinstance(y,bool): raise TypeError",
      " kind,wait_ticks=int(kind),int(wait_ticks)",
      " if not 0<=kind<=3: raise ValueError",
      " if not 0<=wait_ticks<=0xffffffff: raise ValueError",
      " return ipc._STEP_REQUEST.pack(kind,float(x),float(y),wait_ticks,int(bool(suppress_fresh_edges)))",
      "def old_decode(payload,destination):",
      " body_count=ipc._OBSERVATION_HEADER.unpack_from(payload)[15]; body_end=ipc._OBSERVATION_HEADER.size+body_count*ipc._BODY.size",
      " ctypes.memmove(ctypes.addressof(destination.observation),payload,body_end)",
      " for name,value in zip(fields,ipc._TRANSITION.unpack_from(payload,body_end)): setattr(destination,name,value)",
      " generation=ipc._EVENT_GENERATION.unpack_from(payload,body_end+ipc._TRANSITION.size)[0]",
      " return destination,int(generation)",
      "def run(label,iters):",
      " ipc._pack_step_request=old_pack if label=='old' else new_pack; pad._decode_exact_transition=old_decode if label=='old' else new_decode",
      " r=bench.padded_lazy_pipeline(w,iters,[32])['32']; print(json.dumps({'variant':label,'ops_s':r['operations_per_second'],'seconds':r['elapsed_seconds'],'bodies':r['observed_body_count'],'events':r['observed_event_count']}),flush=True); return r['operations_per_second']",
      "try:",
      " run('new',1000)",
      " vals={'old':[],'new':[]}",
      " for label in ('old','new','new','old','old','new'):",
      "  vals[label].append(run(label,2500))",
      " print(json.dumps({'values':vals,'medians':{k:statistics.median(v) for k,v in vals.items()},'ratio':statistics.median(vals['new'])/statistics.median(vals['old'])}),flush=True)",
      "finally: ipc._pack_step_request=new_pack;pad._decode_exact_transition=new_decode"
    ],
